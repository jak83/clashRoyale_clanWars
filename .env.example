# API token from https://developer.clashroyale.com — shared across all clans
CLASH_API_TOKEN=your_api_token_here

# Single-clan setup: set CLAN_TAG to track one clan (no clans.json needed)
CLAN_TAG=#YOUR_CLAN_TAG

# Multi-clan setup: create clans.json in the project root (see clans.json.example).
# When clans.json exists, CLAN_TAG is ignored. CLASH_API_TOKEN is always used.

PORT=3000
HISTORY_PATH=  # Optional: path for history files (e.g., Google Drive folder)
